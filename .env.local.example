# Supabase Dashboard -> Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Dashboard -> Project Settings -> API -> anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Dashboard -> Project Settings -> API -> service_role key
# NEVER expose this client-side. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key for transactional email delivery.
RESEND_API_KEY=

# Verified sender address used by Resend.
RESEND_FROM_EMAIL="AgriRent <noreply@agrirent.shop>"

# Public site URL used to build email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Dashboard -> Project Settings -> Database -> Connection string
# -> Transaction pooler (Supavisor, port 6543) — NOT the direct 5432 string.
DATABASE_URL=

# NVIDIA NIM API key (OpenAI-compatible endpoint). Server-only.
NVIDIA_API_KEY=
